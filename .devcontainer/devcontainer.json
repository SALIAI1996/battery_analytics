{
  "name": "Environmental analytics (FastAPI + React)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "backend/api.py", "frontend-react/src/App.tsx"]
    },
    "vscode": {
      "settings": {},
      "extensions": ["ms-python.python", "ms-python.vscode-pylance", "dbaeumer.vscode-eslint"]
    }
  },
  "updateContentCommand": "[ -f requirements.txt ] && pip3 install --user -r requirements.txt; [ -d frontend-react ] && cd frontend-react && npm install; echo '✅ Python + Node deps installed'",
  "portsAttributes": {
    "5173": {
      "label": "Vite (React)",
      "onAutoForward": "notify"
    },
    "8004": {
      "label": "FastAPI",
      "onAutoForward": "notify"
    }
  },
  "forwardPorts": [5173, 8004]
}
