# Copy to ".env" in this directory (repo root) and adjust.
# Loaded automatically when the FastAPI app starts (see backend/api.py).

# Comma-separated browser origins allowed to call the API (production).
# Use * for allow-all (default). If the Vercel UI cannot reach the API, set your exact origins, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app
CORS_ORIGINS=*

# ThingSpeak read key (optional). If set, POST /connect-thingspeak can omit read_api_key.
THINGSPEAK_READ_API_KEY=

# Serial / ADC parsing (optional; used in backend/sc05_uart.py when parsing UART lines)
# ADC_VREF=5.0
# ADC_DIVIDER=1.0
# ADC_BITS_MAX=1023
