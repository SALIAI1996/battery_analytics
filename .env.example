# Copy to ".env" in this directory (repo root) and adjust.
# Loaded automatically when the FastAPI app starts (see backend/api.py).

# Comma-separated browser origins allowed to call the API (production).
# Use * for allow-all (default). If the Vercel UI cannot reach the API, set your exact origins, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app
CORS_ORIGINS=*

# ThingSpeak — channel 3337776 (IOT BASED BMS). Use your read API key from ThingSpeak (do not commit real keys).
# Required for /thingspeak/channel-status, /thingspeak/feeds, /thingspeak/fields/*/data proxy routes.
THINGSPEAK_READ_API_KEY=
# Optional override (default 3337776)
THINGSPEAK_CHANNEL_ID=3337776

# Channel 3337776 supports:
# - BMS text in any field: "V1=3.7,...,I=1.2A,T=30C,SOC=75%"
# - OR numeric fields mapping: field1..4=V1..V4, field5=I(A), field6=T(°C), field7=SOC(%)

# Serial / ADC parsing (optional; used in backend/sc05_uart.py when parsing UART lines)
# ADC_VREF=5.0
# ADC_DIVIDER=1.0
# ADC_BITS_MAX=1023
