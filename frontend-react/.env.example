# Copy to ".env" or ".env.local" in this directory (frontend-react/).
# Vite exposes only variables prefixed with VITE_.

# Public URL of the FastAPI backend (production / Render). No trailing slash.
# Leave empty for local dev: the Vite dev server proxies /api → http://127.0.0.1:8004
# Example:
# VITE_API_URL=https://your-api.onrender.com

VITE_API_URL=
