{
  "name": "battery-analytics-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npx --yes vercel@latest",
    "deploy:prod": "npx --yes vercel@latest --prod",
    "deploy:prod:debug": "VERCEL_DEBUG=1 npx --yes vercel@latest --prod",
    "deploy:prod:prebuilt": "npx --yes vercel@latest build && npx --yes vercel@latest deploy --prebuilt --prod"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
